# Centralized secrets for the home-server deploy pipeline.
#
# Copy this file to `.env` (which is git-ignored) and fill in real values:
#
#     cp .env.template .env && $EDITOR .env
#
# `update.sh` sources this with POSIX `.` (shell KEY=VALUE), so:
#   - QUOTE any value containing spaces or shell metacharacters,
#     e.g. SECRET_PASS="my wifi pass".
#   - No spaces around `=`.
#   - Nothing here is committed; the Arduino `arduino_secrets.h` generated
#     from these values is deleted right after each compile.

# --- Arduino node `sypialnia` (compiled into the firmware) ---
SECRET_SSID="your-wifi-ssid"
SECRET_PASS="your-wifi-password"
SECRET_OTA_PASS="password"          # ArduinoOTA password (waku default: "password")

# --- MQTT (Arduino publishes here; raspberry-hex brokers + ingests) ---
MQTT_HOST="raspberry.local"         # broker host reachable from the Arduino
MQTT_PORT=1883

# --- raspberry-hex CO2 dashboard ---
DASHBOARD_PORT=8080                 # LAN port for the time-series dashboard
